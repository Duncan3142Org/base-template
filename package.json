{
	"name": "@deafrex/node-template",
	"description": "Node.js repo template",
	"version": "1.4.19",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/deafrex/node-template.git"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com"
	},
	"type": "module",
	"license": "AGPL-3.0-only",
	"engines": {
		"node": ">=24",
		"npm": ">=11"
	},
	"files": [
		".tsc/dist/**/*"
	],
	"imports": {
		"#src": {
			"@deafrex/node-template:src": "./src/index.ts",
			"default": "./.tsc/dist/index.js"
		},
		"#test/*": {
			"@deafrex/node-template:test": "./test/*/index.ts",
			"default": null
		}
	},
	"exports": {
		".": {
			"types": "./.tsc/dist/index.d.ts",
			"import": "./.tsc/dist/index.js"
		}
	},
	"devDependencies": {
		"@commitlint/config-conventional": "^20.5.0",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
		"@eslint/compat": "^2.0.4",
		"@eslint/config-inspector": "^1.5.0",
		"@eslint/js": "^10.0.1",
		"@types/eslint": "^9.6.1",
		"@types/node": "^24.12.2",
		"@vitest/eslint-plugin": "^1.6.14",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jsdoc": "^62.9.0",
		"execa": "^9.6.1",
		"prettier": "^3.8.1",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	}
}
