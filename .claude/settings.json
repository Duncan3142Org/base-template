{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Read",
			"Glob",
			"Grep",
			"LS",
			"mcp__ide__getDiagnostics",
			"Bash(find:*)",
			"Bash(grep:*)",
			"Bash(wc:*)"
		],
		"defaultMode": "plan"
	},
	"model": "sonnet",
	"autoUpdatesChannel": "stable",
	"enabledPlugins": {
		"skill-creator@claude-plugins-official": true
	}
}
